# ===================================================================
# Codex — variáveis de ambiente
# Copie para .env (cp .env.example .env) e ajuste os valores.
# ===================================================================

# --- Diretório de dados persistentes (volume do PostgreSQL) ---
# Em produção, aponte para um caminho estável, ex.: /mnt/appdata
APPDATA_PATH=./appdata

# --- Porta pública do frontend (Nginx) ---
APP_PORT=4200

# --- Banco de dados PostgreSQL ---
DB_NAME=lexbase
DB_USER=lexbase
DB_PASSWORD=troque-esta-senha-do-banco

# --- Segurança / JWT ---
# Gere uma chave forte, por exemplo: openssl rand -hex 32
SECRET_KEY=troque-por-uma-chave-secreta-bem-longa-e-aleatoria
TOKEN_EXPIRE=480

# --- Administrador inicial (criado automaticamente no primeiro startup) ---
ADMIN_EMAIL=admin@codex.local
ADMIN_PASSWORD=troque-esta-senha-do-admin
ADMIN_NOME=Administrador

# --- Fuso horário do scheduler (sincronização diária às 03h) ---
TIMEZONE=America/Porto_Velho
